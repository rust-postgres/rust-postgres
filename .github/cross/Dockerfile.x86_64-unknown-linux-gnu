# CentOS 7 (glibc 2.17) for maximum Linux compatibility.
# Binaries built here will run on any system with glibc >= 2.17,
# which covers glibc 2.22+ as required.
FROM centos:7

# CentOS 7 reached EOL on 2024-06-30; switch to vault mirrors.
RUN sed -i 's|^mirrorlist=|#mirrorlist=|g' /etc/yum.repos.d/CentOS-*.repo && \
    sed -i 's|^#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' /etc/yum.repos.d/CentOS-*.repo

RUN yum install -y gcc gcc-c++ make perl pkgconfig && \
    yum clean all
