FROM messense/manylinux2014-cross:aarch64

# Host-side build deps (x86_64 headers for cross-compilation reference)
RUN yum install -y perl-core dbus-devel pkgconfig && \
    yum clean all

# Install aarch64 dbus libraries into cross-compilation sysroot
# for libdbus-sys to link against during cross-compilation.
RUN cd /tmp && \
    curl -sSL http://vault.centos.org/7.9.2009/os/aarch64/Packages/dbus-libs-1.10.24-13.el7.aarch64.rpm -o dbus-libs.rpm && \
    curl -sSL http://vault.centos.org/7.9.2009/os/aarch64/Packages/dbus-devel-1.10.24-13.el7.aarch64.rpm -o dbus-devel.rpm && \
    rpm2cpio dbus-libs.rpm | cpio -idm && \
    rpm2cpio dbus-devel.rpm | cpio -idm && \
    mkdir -p /usr/aarch64-linux-gnu/lib && \
    cp -a usr/lib64/libdbus-1.so* /usr/aarch64-linux-gnu/lib/ && \
    mkdir -p /usr/aarch64-linux-gnu/include/dbus-1.0/dbus && \
    cp -a usr/include/dbus-1.0/dbus/*.h /usr/aarch64-linux-gnu/include/dbus-1.0/dbus/ && \
    mkdir -p /usr/aarch64-linux-gnu/lib/dbus-1.0/include/dbus && \
    cp -a usr/lib64/dbus-1.0/include/dbus/dbus-arch-deps.h /usr/aarch64-linux-gnu/lib/dbus-1.0/include/dbus/ && \
    mkdir -p /usr/aarch64-linux-gnu/lib/pkgconfig && \
    sed 's|/usr/lib64|/usr/aarch64-linux-gnu/lib|g; s|/usr/include|/usr/aarch64-linux-gnu/include|g' \
        usr/lib64/pkgconfig/dbus-1.pc > /usr/aarch64-linux-gnu/lib/pkgconfig/dbus-1.pc && \
    rm -rf /tmp/usr /tmp/dbus*.rpm
